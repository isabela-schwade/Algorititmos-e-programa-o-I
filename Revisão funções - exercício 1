/* 1)	Elabore um programa, que deve utilizar uma função  para resolver a multiplicação de dois números naturais, através de somas sucessivas. A impressão do resultado deve ser realizada na main.
Por exemplo: 6 ∗ 4 = 4 + 4 + 4 + 4 + 4 + 4).
Implementações que não utilizarem função não serão consideradas.
Realize as consistências de dados necessárias. Lembrando, que um número natural é um inteiro positivo.
*/
#include <stdio.h>
int multiplicacao(int n1,int n2);
int main() {
    
    int numero1, numero2, resultado;
    printf("Informe um número inteiro positivo: ");
    scanf("%d", &numero1);
    
    while(numero1 < 0){
         printf("\nInforme um número inteiro positivo: ");
         scanf("%d", &numero1);
    }
    
    printf("Informe outro número inteiro positivo: ");
    scanf("%d", &numero2);
    
    while(numero2 < 0){
         printf("\nInforme um número inteiro positivo: ");
         scanf("%d", &numero2);
    }
    
    resultado = multiplicacao(numero1,numero2);
    printf("\nResultado: %d", resultado);

    return 0;
}
int multiplicacao(int n1, int n2){
    int i, soma = 0;
    
    for(i = 0; i < n1; i++){
        soma = soma + n2;
    }
    return soma;
}
