}
void imprime(int l1,int l2, int l3){
    if(l1 == l2 && l2 == l3){
        printf("\nO triângulo é equilátero!");
    }
    else{
        if(l1 != l2 && l2 != l3 && l1 != l3){
             printf("\nO triângulo é escaleno!");
        }
        else{
             printf("O triângulo é isóceles!");
        }
    }
