void imprime();

#include<stdio.h>
int main(){
    int lado1, lado2, lado3;
    
    printf("Informe o lado 1 do triângulo: ");
    scanf("%d", &lado1);
    
    while(lado1 <= 0){
        printf("Informe um valor maior que 0: ");
