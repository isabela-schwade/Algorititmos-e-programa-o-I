/*
4)	Faça um programa que leia 10 números inteiros, armazene-os em um vetor, solicite um valor de referência inteiro e: a) imprima os números do vetor que são maiores que o valor referência b) retorne quantos números armazenados no vetor são menores que o valor de referência c) retorne quantas vezes o valor de referência aparece no vetor.


*/
#include <stdio.h>

int main() {
    int vetor[10], i, valor, contador=0, menor=0;
    
    printf("Informe um valor de referência: ");
    scanf("%d", &valor);
    
    for(i=0;i<10;i++){
        printf("\nInforme o valor da posição %d ", i+1);
        scanf("%d",&vetor[i]);
        
        if(vetor[i]==valor){
            contador++;
        }
        else{
            if(vetor[i] < valor){
                menor++;
            }
        }
    }
   
   printf("\nExistem %d números iguais ao valor de referência!", contador);
   printf("\nExistem %d números menores que o valor de referência!", menor);
  
    for(i=0; i<9; i++){
        if(vetor[i] > valor){
            printf("\nO número %d é maior que o valor de referência!", vetor[i]);
        }
    }
}
