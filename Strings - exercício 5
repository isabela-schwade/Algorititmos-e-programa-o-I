/*5)	Palíndromo. Um palíndromo é uma seqüência de caracteres cuja leitura é idêntica se feita da direita para esquerda ou vice−versa. Por exemplo: OSSO e OVO são palíndromos. Em textos mais complexos os espaços e pontuação são ignorados. A frase SUBI NO ONIBUS é o exemplo de uma frase palíndroma onde os espaços foram ignorados. Faça um programa que leia uma seqüência de caracteres, mostre−a e diga se é um palíndromo ou não..
.*/
#include <stdio.h>
#include <string.h>

int main() {

   char frase[40], frase2[40];
   int i, tamanho, cont=0, j;
   
   printf("Digite uma frase: ");
   fgets(frase, 40, stdin);
    
   frase[strcspn(frase, "\n")] = '\0';
tamanho = strlen(frase);
  
   j = 0;
   for(i = tamanho -1; i>=0; i--){
      
       frase2[j] = frase[i];
       j++;
   }
   frase2[j] = '\0';
   
   for(i=0; i<tamanho;i++){
       if(frase[i] != frase2[i]){
           cont++;
       }
   }
  
  if(cont == 0){
      printf("\nA frase é um palíndromo!");
  }
  else{
      printf("\nA frase não é um palíndromo!");
  }
  
}
