/*
2)	Faça uma função que recebe um valor inteiro e verifica se o valor é positivo, negativo ou zero. A função deve retornar 1 para valores positivos, -1 para negativos e 0 para o valor 0.
*/

int verifica(int num);
#include<stdio.h>
#include<math.h>
int main(){
    
   int numero, op;
   printf("Digite um número: ");
   scanf("%d", &numero);
   op = verifica(numero);
   
   switch(op){
        case 1:
            printf("\nO número é positivo!");
            break;
        case -1:
            printf("\nO número é negativo!");
            break;
        default: 
            printf("O número é zero!");
            break;
   }    
   
}
int verifica(int num){
    if(num > 0){
        return 1;
    }
    else{
        if(num < 0){
            return -1;
        }
        else{
            return 0;
        }
    }
}
