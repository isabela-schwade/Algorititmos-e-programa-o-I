/*
1)	Faça um programa que leia 5 valores inteiros, armazeno-os em um vetor, calcule e apresente a soma destes valores.
*/
#include <stdio.h>

int main() {
    int vetor[5], i, soma=0;
    
    for(i=0;i<5;i++){
        printf("\nInforme o valor da posição %d ", i+1);
        scanf("%d",&vetor[i]);
        soma = soma+vetor[i];
    }
    printf("\nA soma dos valores é %d",soma);
}
