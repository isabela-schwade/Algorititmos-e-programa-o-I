    int matriz[2][2], i, j, matriz2[2][2],cont=0;
    
   
    for(i=0; i<2; i++){
        for(int j=0; j<2; j++){
            printf("\nInforme o valor da linha %d coluna %d: ",i+1,j+1);
            scanf("%d", &matriz[i][j]);
    }
    }
    
    printf("\nMatriz 1 finalizada!");
    
