/*
3)	Faça um programa que leia 10 valores reais e os apresente na ordem inversa entrada.
*/
#include <stdio.h>

int main() {
    int vetor[10], i;
    
    for(i=0;i<10;i++){
        printf("\nInforme o valor da posição %d ", i+1);
        scanf("%d",&vetor[i]);
    }
    printf("\nOrdem inversa!");
    for(i=9; i>=0; i--){
        printf("\n%d", vetor[i]);
    }
}
