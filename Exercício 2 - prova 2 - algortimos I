// Online C compiler to run C program online
#include <stdio.h>

int main() {
    
   int vagas[6] [6] = {0}, vaga, corredor,i,j;
   int vagas_ocupadas = 0, vagas_livres_corredor = 0, vagas_ocupadas_diagonal = 0, opcao;
   
   printf("-----MENU-----");
   printf("\n1 - Ocupar vaga.");
   printf("\n2 - Consultar quantidade total de vagas ocupadas.");
   printf("\n3 - Consultar quantidade de fagas livres por corredor.");
   printf("\n4 - Consultar quantidade de vagas livres na diagonal princial..");
   printf("\n5 - Encerrar programa.");
   printf("\nInforme a opção desejada: ");
   scanf("%d", &opcao);
   
   while(opcao < 1 || opcao > 5){
       printf("\nInforme uma opção válida: ");
       scanf("%d", &opcao);
   }
   
   while(opcao != 5){
       
       switch(opcao){
           
           case 1:
                printf("\nInforme o corredor que deseja: ");
                scanf("%d", &corredor);
                
                while(corredor < 1 || corredor > 6){
                    printf("\nInforme um corredor válido: ");
                    scanf("%d", &corredor);
                }
                
                printf("\nInforme a vaga que deseja: ");
                scanf("%d", &vaga);
                
                while(vaga < 1 || vaga > 6){
                    printf("\nInforme uma vaga válida: ");
                    scanf("%d", &vaga);
                }
                
                while(vagas[vaga] [corredor] == 1){
                    printf("\nVaga já ocupada. Escolha outra.");
                   
                    printf("\nInforme o corredor que deseja: ");
                    scanf("%d", &corredor);
                
                    while(corredor < 1 || corredor > 6){
                        printf("\nInforme um corredor válido: ");
                        scanf("%d", &corredor);
                    }
                
                    printf("\nInforme a vaga que deseja: ");
                    scanf("%d", &vaga);
                
                    while(vaga < 1 || vaga > 6){
                        printf("\nInforme uma vaga válida: ");
                        scanf("%d", &vaga);
                    }
                }
                
                vagas[vaga-1][corredor-1] = 1;
                
                printf("\nVaga ocupado com sucesso!");
                break;
            
            case 2:
                for(i = 0; i<6; i++){
                    for(j=0; j <6; j++){
                        if(vagas[i][j] == 1){
                            vagas_ocupadas++;
                        }
                    }
                }
                printf("\nO total de vagas ocupadas é %d", vagas_ocupadas);
                break;
            
            case 3:
                for(j = 0; j<6; j++){
                    vagas_livres_corredor = 0;
                    for(i=0; i <6; i++){
                        if(vagas[i][j] == 0){
                            vagas_livres_corredor++;
                        }
                    }
                     printf("\nO total de vagas livres no corredor %d é %d", j+1, vagas_livres_corredor);
                }
                printf("\nO total de vagas ocupadas é %d", vagas_ocupadas);
                break;
            
            case 4:
            
                for(i=0;i<6;i++){
                    if(vagas[i][i]==1){
                        vagas_ocupadas_diagonal++;
                    }
                }
                
                printf("\nExistem %d vagas ocupadas na diagonal principal.",vagas_ocupadas_diagonal);
       }
    printf("\n-----MENU-----");
   printf("\n1 - Ocupar vaga.");
   printf("\n2 - Consultar quantidade total de vagas ocupadas.");
   printf("\n3 - Consultar quantidade de fagas livres por corredor.");
   printf("\n4 - Consultar quantidade de vagas livres na diagonal princial..");
   printf("\n5 - Encerrar programa.");
   printf("\nInforme a opção desejada: ");
   scanf("%d", &opcao);
   }
   printf("\nFIM DO PROGRAMA!");
}
