// 3)	Faça um programa que manipule com uma matriz 4 x 4 de inteiros, imprima a matriz e retorne a localização (linha e a coluna) do maior valor. 
#include <stdio.h>

int main() {
    int matriz[4][4], i, j, maior=0, linha, coluna;
    
    for(i=0; i<4; i++){
        for(int j=0; j<4; j++){
            printf("\nInforme o valor da linha %d coluna %d: ",i+1,j+1);
            scanf("%d", &matriz[i][j]);
            if(matriz[i][j]>maior){
                maior = matriz[i][j];
                linha = i;
                coluna = j;
            }
    }
    }

   printf("\n----MATRIZ----\n");
   for(i=0;i<4;i++){
       for(j=0;j<4;j++){
           printf("%d ", matriz[i][j]);
       }
       printf("\n");
   }
   printf("\nO maior valor da matriz é %d, e ele fica na linha %d e na coluna %d ", maior, linha+1, coluna+1);
   
}
