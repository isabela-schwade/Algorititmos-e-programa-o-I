/*
Crie um aplicativo de conversão entre as temperaturas Celsius e Farenheit.
Primeiro o usuário deve escolher se vai entrar com a temperatura em Célsius ou Farenheit, depois a conversão escolhida é realizada através de um comando SWITCH.
Se C é a temperatura em Célsius e F em farenheit, as fórmulas de conversão são:
C= 5.(F-32)/9
F= (9.C/5) + 32


%¨&*/


float calculacelcius(float temperatura);
float calculafarenheit(float temperatura);

#include<stdio.h>
#include<math.h>
int main(){
    
   int op;
   float temp, farenheit , celcius;
   printf("\nDigite 1 para converter de celcius para farenheit e 2 para converter de farenheit para celcius: ");
   scanf("%d", &op);
   
   switch (op){
   
        case 1:
            printf("\nInforme a temperatura em celcius: ");
            scanf("%f", &temp);

            farenheit = calculafarenheit(temp);
            printf("%f graus celcius equivalema %f graus farenheit.", temp, farenheit);
            break;
    
        case 2:
            printf("\nInforme a temperatura em farenheit: ");
            scanf("%f", &temp);
            celcius = calculacelcius(temp);
            printf("%f graus celcius equivalema %f graus farenheit.", temp, celcius);
            break;
    
    }
}

float calculacelcius(float temperatura){
    float resultado = (5*(temperatura-32))/9;
    return resultado;
}

float calculafarenheit(float temperatura){
    float resultado = ((9*temperatura)/5) + 32;
    return resultado;

}
